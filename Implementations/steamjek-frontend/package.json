{
  "name": "steamjek-native",
  "version": "1.0.0",
  "description": "SteamJek Native Desktop Client",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "author": "SteamJek",
  "license": "ISC",
  "build": {
    "appId": "com.steamjek.app",
    "productName": "SteamJek",
    "win": {
      "target": "nsis"
    },
    "files": [
      "**/*",
      {
        "from": "../steamjek-backend",
        "to": "backend",
        "filter": [
          "**/*",
          "!node_modules/**",
          "!tests/**",
          "!tests_output*.log",
          "!test_results.txt"
        ]
      }
    ]
  },
  "devDependencies": {
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "pg": "^8.20.0",
    "stripe": "^20.4.1"
  }
}
